{
  "name": "lens",
  "version": "0.1.0",
  "private": true,
  "description": "Audit any AI shopping recommendation. Built with Claude Opus 4.7.",
  "license": "MIT",
  "author": "Felipe Affonso",
  "type": "module",
  "workspaces": [
    "apps/*",
    "workers/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev -w @lens/api",
    "dev:web": "npm run dev -w @lens/web",
    "deploy:api": "npm run deploy -w @lens/api",
    "deploy:cross": "npm run deploy -w @lens/cross-model",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,html,css}\"",
    "packs:bundle": "node scripts/bundle-packs.mjs",
    "packs:validate": "node scripts/validate-pack-schema.mjs",
    "packs:judge": "node scripts/validate-packs.mjs",
    "packs:enrich": "node scripts/enrich-pack.mjs --all",
    "packs:reg-watch": "node scripts/check-regulation-status.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:shared": "vitest run --project @lens/shared",
    "test:workers": "vitest run --project @lens/api --project @lens/cross-model",
    "test:web": "vitest run --project @lens/web",
    "test:coverage": "vitest run --coverage",
    "test:e2e:web": "playwright test -c apps/web/playwright.config.ts",
    "test:e2e:ext": "playwright test -c apps/extension/playwright.config.ts",
    "test:ci": "npm run test && npm run test:e2e:web"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "@vitest/coverage-v8": "^2.1.3",
    "happy-dom": "^15.7.4",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
