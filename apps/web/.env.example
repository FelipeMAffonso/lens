# apps/web — Vite env for local dev + preview builds.
# Copy to `.env.local` (gitignored) and restart `npm run dev`.
# Full reference: ../../docs/secrets.md
#
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# Override the API origin the web app targets. Default is the production
# worker. Point this at a local `wrangler dev` session (usually
# http://127.0.0.1:8787) or a preview deploy when testing staging changes.
VITE_LENS_API_URL=https://lens-api.webmarinelli.workers.dev
